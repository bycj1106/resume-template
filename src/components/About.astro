---
import { resumeData } from '../data/resume';
import GlassCard from './GlassCard.astro';

const { about } = resumeData;
---

<GlassCard delay={320}>
  <h2 class="text-lg font-semibold text-slate-800 mb-4">
    About Me
  </h2>
  <div class="space-y-2">
    {about.map((paragraph) => (
      <p class="text-slate-600 leading-relaxed text-sm">
        {paragraph}
      </p>
    ))}
  </div>
</GlassCard>
