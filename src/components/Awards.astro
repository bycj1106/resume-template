---
import { resumeData } from '../data/resume';
import GlassCard from './GlassCard.astro';
import Icon from './Icon.astro';

const { awards } = resumeData;
---

<GlassCard delay={560}>
  <h2 class="text-lg font-semibold text-slate-800 mb-5">
    Awards & Honors
  </h2>
  
  <div class="space-y-3">
    {awards.map((award) => (
      <div class="glass rounded-xl p-4 hover:bg-white/70 transition-colors duration-200">
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-xl bg-rose-100 flex items-center justify-center flex-shrink-0">
            <Icon name="award" class="w-5 h-5 text-rose-600" />
          </div>
          
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap justify-between items-start gap-2 mb-1">
              <h3 class="text-sm font-semibold text-slate-800">{award.name}</h3>
              <span class="text-xs text-slate-500 bg-white/60 px-2 py-0.5 rounded-full border border-slate-200/50">
                {award.period}
              </span>
            </div>
            <p class="text-cyan-600 text-sm">{award.organization}</p>
            {award.description && (
              <p class="text-slate-500 text-xs mt-1">{award.description}</p>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>
</GlassCard>
