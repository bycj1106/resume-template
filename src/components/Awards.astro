---
import { resumeData } from '../data/resume';
import GlassCard from './GlassCard.astro';
import Icon from './Icon.astro';

const { awards } = resumeData;
---

<GlassCard delay={240}>
  <h2 class="text-lg font-semibold text-slate-800 mb-4">
    Awards & Honors
  </h2>
  
  <div class="space-y-2.5">
    {awards.map((award) => (
      <div class="p-3 rounded-lg bg-white/15 border border-white/20 hover:bg-white/25 hover:border-white/35 transition-all duration-200">
        <div class="flex gap-3">
          <div class="w-9 h-9 rounded-lg bg-rose-100/60 flex items-center justify-center flex-shrink-0">
            <Icon name="award" class="w-4 h-4 text-rose-600" />
          </div>
          
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap justify-between items-start gap-2 mb-1">
              <h3 class="text-sm font-semibold text-slate-800">{award.name}</h3>
              <span class="text-xs text-slate-500 bg-white/30 px-2 py-0.5 rounded-full border border-white/20">
                {award.period}
              </span>
            </div>
            <p class="text-cyan-600 text-sm font-medium">{award.organization}</p>
            {award.description && (
              <p class="text-slate-500 text-xs mt-1.5">{award.description}</p>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>
</GlassCard>
