---
import { resumeData } from '../data/resume';
import GlassCard from './GlassCard.astro';
import Icon from './Icon.astro';

const { email } = resumeData;
---

<GlassCard delay={640}>
  <h2 class="text-lg font-semibold text-slate-800 mb-3">
    Contact
  </h2>
  
  <div class="flex flex-col items-center text-center">
    <div class="relative mb-3">
      <div class="absolute -inset-2.5 bg-gradient-to-r from-violet-400 to-purple-400 rounded-xl blur-lg opacity-30"></div>
      <div class="relative w-14 h-14 rounded-xl bg-gradient-to-br from-violet-100/60 to-purple-100/60 border border-white/50 flex items-center justify-center shadow-md">
        <Icon name="mail" class="w-6 h-6 text-violet-600" />
      </div>
    </div>
    
    <p class="text-slate-500 text-sm mb-3">
      Feel free to reach out for collaborations
    </p>
    
    <a
      href={`mailto:${email}`}
      class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-violet-600 to-purple-600 text-white rounded-lg font-medium text-sm hover:shadow-lg hover:shadow-violet-500/25 hover:-translate-y-0.5 transition-all duration-200"
    >
      <Icon name="mail" class="w-4 h-4" />
      {email}
    </a>
  </div>
</GlassCard>
