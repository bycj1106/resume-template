---
import { resumeData } from '../data/resume';
import GlassCard from './GlassCard.astro';
import Icon from './Icon.astro';

const { education } = resumeData;
---

<GlassCard delay={240}>
  <h2 class="text-lg font-semibold text-slate-800 mb-6">
    Education
  </h2>
  
  <div class="space-y-3">
    {education.map((edu) => (
      <div class="glass rounded-xl p-4 hover:bg-white/70 transition-colors duration-200">
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-xl bg-violet-100 flex items-center justify-center flex-shrink-0">
            <Icon name="graduation-cap" class="w-5 h-5 text-violet-600" />
          </div>
          
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap justify-between items-start gap-2 mb-1">
              <h3 class="text-sm font-semibold text-slate-800">{edu.school}</h3>
              <span class="text-xs text-slate-500 bg-white/60 px-2 py-0.5 rounded-full border border-slate-200/50">
                {edu.period}
              </span>
            </div>
            <p class="text-cyan-600 text-sm">{edu.degree}</p>
            {edu.description && (
              <p class="text-slate-500 text-xs mt-1">{edu.description}</p>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>
</GlassCard>
