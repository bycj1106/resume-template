---
interface Props {
  class?: string;
  hover?: boolean;
  delay?: number;
}

const { class: className = "", hover = true, delay = 0 } = Astro.props;
---

<div 
  class:list={[
    "glass-card",
    hover && "glass-card-hover",
    className
  ]}
  style={delay ? `animation-delay: ${delay}ms` : undefined}
  data-animate
>
  <slot />
</div>

<style>
  [data-animate] {
    opacity: 0;
    animation: slideUpCard 0.6s ease-out forwards;
    -webkit-animation: slideUpCard 0.6s ease-out forwards;
  }
</style>
