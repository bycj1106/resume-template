---
import { resumeData } from '../data/resume';
import type { IconName } from '../types/resume';
import GlassCard from './GlassCard.astro';
import Icon from './Icon.astro';

const { name, title, avatar, summary, socials, email } = resumeData;
---

<GlassCard class="glass-enter">
  <div class="flex flex-col lg:flex-row items-center lg:items-start gap-6">
    <!-- Avatar -->
    <div class="relative flex-shrink-0">
      <div class="absolute -inset-3 bg-gradient-to-r from-blue-400 via-cyan-400 to-blue-400 rounded-full blur-xl opacity-40"></div>
      <div class="relative w-24 h-24 lg:w-28 lg:h-28 rounded-full overflow-hidden border-[2.5px] border-white/80 shadow-xl">
        <img 
          src={avatar} 
          alt={`${name}'s avatar`}
          title={name}
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
          onerror="this.onerror=null; this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22%3E%3Crect fill=%22%23e2e8f0%22 width=%22100%22 height=%22100%22/%3E%3Ctext x=%2250%25%22 y=%2250%25%22 dominant-baseline=%22middle%22 text-anchor=%22middle%22 fill=%22%2394a3b8%22 font-size=%2240%22%3E%3C/text%3E%3C/svg%3E'"
        />
      </div>
    </div>

    <!-- Info -->
    <div class="flex-1 text-center lg:text-left">
      <h1 class="text-xl lg:text-2xl font-bold text-slate-800">
        {name}
      </h1>
      <p class="text-blue-600 font-medium text-base mb-2">
        {title}
      </p>
      <p class="text-slate-500 text-sm mb-4 max-w-lg leading-relaxed">
        {summary}
      </p>

      <!-- Social links -->
      <div class="flex justify-center lg:justify-start gap-2 mb-4">
        {socials.map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-lg bg-white/30 backdrop-blur-sm border border-white/40 flex items-center justify-center text-slate-500 hover:text-blue-600 hover:bg-white/50 transition-all duration-200"
            aria-label={social.name}
          >
            <Icon name={social.icon as IconName} class="w-4 h-4" />
          </a>
        ))}
      </div>

      <!-- CTA -->
      <a
        href={`mailto:${email}`}
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-blue-600 to-cyan-600 text-white rounded-lg font-medium text-sm hover:shadow-lg hover:shadow-blue-500/25 hover:-translate-y-0.5 transition-all duration-200"
      >
        <Icon name="mail" class="w-4 h-4" />
        Contact Me
      </a>
    </div>
  </div>
</GlassCard>
