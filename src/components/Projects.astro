---
import { resumeData } from '../data/resume';
import GlassCard from './GlassCard.astro';
import Icon from './Icon.astro';

const { workProjects, personalProjects } = resumeData;
---

<GlassCard delay={400}>
  <h2 class="text-lg font-semibold text-slate-800 mb-5">
    Work Projects
  </h2>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {workProjects.map((project) => (
      <div class="glass rounded-xl p-4 hover:bg-white/70 transition-colors duration-200 group">
        <div class="space-y-3">
          <div class="flex items-start justify-between gap-2">
            <h3 class="text-sm font-semibold text-slate-800 group-hover:text-violet-700 transition-colors">
              {project.name}
            </h3>
            {project.featured && (
              <span class="text-[10px] bg-violet-100 text-violet-700 px-2 py-0.5 rounded border border-violet-200">
                Featured
              </span>
            )}
          </div>
          
          <p class="text-slate-500 text-xs leading-relaxed">
            {project.description}
          </p>
          
          <div class="flex flex-wrap gap-1.5">
            {project.tags.map((tag) => (
              <span class="text-[10px] bg-white/60 text-slate-500 px-2 py-0.5 rounded border border-slate-200/50">
                {tag}
              </span>
            ))}
          </div>
          
          {project.link && (
            <a
              href={project.link}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-xs text-cyan-600 hover:text-violet-700 transition-colors"
            >
              <span>Details</span>
              <Icon name="external-link" class="w-3 h-3" />
            </a>
          )}
        </div>
      </div>
    ))}
  </div>
</GlassCard>

<GlassCard class="mt-4" delay={480}>
  <h2 class="text-lg font-semibold text-slate-800 mb-5">
    Personal Projects
  </h2>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {personalProjects.map((project) => (
      <div class="glass rounded-xl p-4 hover:bg-white/70 transition-colors duration-200 group">
        <div class="space-y-3">
          <div class="flex items-start justify-between gap-2">
            <h3 class="text-sm font-semibold text-slate-800 group-hover:text-cyan-700 transition-colors">
              {project.name}
            </h3>
            {project.featured && (
              <span class="text-[10px] bg-cyan-100 text-cyan-700 px-2 py-0.5 rounded border border-cyan-200">
                Featured
              </span>
            )}
          </div>
          
          <p class="text-slate-500 text-xs leading-relaxed">
            {project.description}
          </p>
          
          <div class="flex flex-wrap gap-1.5">
            {project.tags.map((tag) => (
              <span class="text-[10px] bg-white/60 text-slate-500 px-2 py-0.5 rounded border border-slate-200/50">
                {tag}
              </span>
            ))}
          </div>
          
          {project.github && (
            <a
              href={project.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-xs text-slate-500 hover:text-slate-800 transition-colors"
            >
              <Icon name="github" class="w-3 h-3" />
              <span>GitHub</span>
            </a>
          )}
        </div>
      </div>
    ))}
  </div>
</GlassCard>
