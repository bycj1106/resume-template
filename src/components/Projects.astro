---
import { resumeData } from '../data/resume';
import GlassCard from './GlassCard.astro';
import Icon from './Icon.astro';

const { workProjects, personalProjects } = resumeData;
---

<GlassCard>
  <h2 class="text-xl font-bold text-slate-800 mb-6 flex items-center gap-2">
    <span class="w-1 h-6 bg-gradient-to-b from-primary to-secondary rounded-full"></span>
    Work Projects
  </h2>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {workProjects.map((project, index) => (
      <div 
        class="group relative glass-strong rounded-xl p-5 hover:-translate-y-1 transition-all duration-300 hover:shadow-xl hover:shadow-primary/10 hover:border-white/90"
        style={`animation-delay: ${index * 100}ms`}
      >
        <div class="space-y-3">
          <div class="flex items-start justify-between gap-2">
            <h3 class="text-lg font-semibold text-slate-800 group-hover:text-primary transition-colors">
              {project.name}
            </h3>
            {project.featured && (
              <span class="text-xs bg-gradient-to-r from-primary/15 to-secondary/15 text-primary px-2 py-0.5 rounded-full border border-primary/20">
                Featured
              </span>
            )}
          </div>
          
          <p class="text-slate-500 text-sm leading-relaxed">
            {project.description}
          </p>
          
          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md border border-slate-200">
                {tag}
              </span>
            ))}
          </div>
          
          {project.link && (
            <a
              href={project.link}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-sm text-secondary hover:text-primary transition-colors"
            >
              View Details
              <Icon name="external-link" class="w-3 h-3" />
            </a>
          )}
        </div>
      </div>
    ))}
  </div>
</GlassCard>

<GlassCard class="mt-6">
  <h2 class="text-xl font-bold text-slate-800 mb-6 flex items-center gap-2">
    <span class="w-1 h-6 bg-gradient-to-b from-primary to-secondary rounded-full"></span>
    Personal Projects
  </h2>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {personalProjects.map((project, index) => (
      <div 
        class="group relative glass rounded-xl p-5 hover:-translate-y-1 transition-all duration-300 hover:shadow-lg hover:shadow-secondary/10 hover:border-white/80"
        style={`animation-delay: ${index * 100}ms`}
      >
        <div class="space-y-3">
          <div class="flex items-start justify-between gap-2">
            <h3 class="text-lg font-semibold text-slate-800 group-hover:text-secondary transition-colors">
              {project.name}
            </h3>
            {project.featured && (
              <span class="text-xs bg-gradient-to-r from-secondary/15 to-accent/15 text-secondary px-2 py-0.5 rounded-full border border-secondary/20">
                Featured
              </span>
            )}
          </div>
          
          <p class="text-slate-500 text-sm leading-relaxed">
            {project.description}
          </p>
          
          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md border border-slate-200">
                {tag}
              </span>
            ))}
          </div>
          
          {project.github && (
            <a
              href={project.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-800 transition-colors"
            >
              <Icon name="github" class="w-4 h-4" />
              GitHub
            </a>
          )}
        </div>
      </div>
    ))}
  </div>
</GlassCard>
