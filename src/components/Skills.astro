---
import { resumeData } from '../data/resume';
import type { IconName } from '../types/resume';
import GlassCard from './GlassCard.astro';
import Icon from './Icon.astro';

const { skills } = resumeData;
---

<GlassCard delay={480}>
  <h2 class="text-lg font-semibold text-slate-800 mb-4">
    Skills & Expertise
  </h2>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {skills.map((category) => (
      <div class="space-y-2">
        <h3 class="text-xs font-semibold text-cyan-600 uppercase tracking-wider flex items-center gap-2">
          <Icon name={category.icon as IconName} class="w-3.5 h-3.5" />
          {category.name}
        </h3>
        
        <div class="flex flex-wrap gap-1.5">
          {category.skills.map((skill) => (
            <span class="text-xs px-2.5 py-1 bg-white/35 border border-white/35 rounded-lg text-slate-600 hover:bg-white/50 hover:border-white/50 hover:text-violet-700 transition-all duration-200">
              {skill.name}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</GlassCard>
