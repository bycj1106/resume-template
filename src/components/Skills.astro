---
import { resumeData } from '../data/resume';
import type { IconName } from '../types/resume';
import GlassCard from './GlassCard.astro';
import Icon from './Icon.astro';

const { skills } = resumeData;
---

<GlassCard delay={320}>
  <h2 class="text-lg font-semibold text-slate-800 mb-6">
    Skills & Expertise
  </h2>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {skills.map((category) => (
      <div class="space-y-3">
        <h3 class="text-xs font-semibold text-cyan-600 uppercase tracking-wider flex items-center gap-2">
          <Icon name={category.icon as IconName} class="w-3.5 h-3.5" />
          {category.name}
        </h3>
        
        <div class="flex flex-wrap gap-2">
          {category.skills.map((skill) => (
            <span class="text-xs px-3 py-1.5 bg-white/50 border border-slate-200/50 rounded-lg text-slate-600 hover:bg-white hover:border-violet-300 hover:text-violet-700 transition-all duration-200">
              {skill.name}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</GlassCard>
