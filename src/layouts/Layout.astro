---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { 
  title, 
  description = "Personal Resume",
  image = "/og-image.svg"
} = Astro.props;

const siteUrl = Astro.site ? Astro.site.href : 'https://example.com';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#3B82F6" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${image}`} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${image}`} />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&display=swap" rel="stylesheet">

    <style is:global>
      @font-face {
        font-family: 'Noto Sans SC';
        font-style: normal;
        font-weight: 400 700;
        font-display: swap;
        src: url(https://fonts.gstatic.com/s/notisanssc/v15/nwpBtKy2OAdR1K-IwhWudF-R9QMylBJAV3Bo8Kw47FEN_io6npfB.woff2) format('woff2');
        unicode-range: U+4E00-9FFF, U+3400-4DBF, U+3000-303F;
      }
    </style>

    <title>{title}</title>
  </head>
  <body class="bg-slate-100 text-slate-800 min-h-screen overflow-x-hidden font-['Noto_Sans_SC',system-ui,sans-serif]">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:px-4 focus:py-2 focus:bg-blue-600 focus:text-white focus:rounded-lg">
      Skip to main content
    </a>
    <!-- Background Layer with Geometric Patterns -->
    <div class="fixed inset-0 z-0 overflow-hidden">
      <!-- Base gradient -->
      <div class="absolute inset-0 bg-gradient-to-br from-violet-200 via-purple-100 to-cyan-200"></div>
      
      <!-- Noise texture overlay -->
      <div class="absolute inset-0 opacity-[0.015]" style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E&quot;);"></div>
      
      <!-- Large solid circles -->
      <div class="absolute top-[5%] left-[5%] w-[180px] h-[180px] rounded-full bg-blue-400/15"></div>
      <div class="absolute top-[20%] right-[5%] w-[220px] h-[220px] rounded-full bg-cyan-400/10"></div>
      <div class="absolute bottom-[10%] left-[15%] w-[160px] h-[160px] rounded-full bg-rose-400/8"></div>
      
      <!-- Blurred glow orbs -->
      <div class="absolute top-[-5%] left-[20%] w-[400px] h-[400px] rounded-full bg-gradient-to-br from-blue-300/20 via-cyan-300/15 to-transparent blur-[60px]"></div>
      <div class="absolute top-[25%] right-[-5%] w-[350px] h-[350px] rounded-full bg-gradient-to-bl from-cyan-300/15 via-blue-300/10 to-transparent blur-[50px]"></div>
      <div class="absolute bottom-[-5%] left-[30%] w-[300px] h-[300px] rounded-full bg-gradient-to-tr from-rose-300/12 via-pink-300/10 to-transparent blur-[45px]"></div>
      
      <!-- Floating circles -->
      <div class="absolute top-[10%] left-[40%] w-24 h-24 rounded-full bg-blue-300/10 blur-sm animate-[float_18s_ease-in-out_infinite]"></div>
      <div class="absolute top-[30%] right-[35%] w-20 h-20 rounded-full bg-cyan-300/8 blur-sm animate-[float_20s_ease-in-out_infinite]" style="animation-delay: 3s;"></div>
      <div class="absolute bottom-[20%] left-[50%] w-28 h-28 rounded-full bg-rose-300/8 blur-sm animate-[float_22s_ease-in-out_infinite]" style="animation-delay: 5s;"></div>
      
      <!-- Subtle grid -->
      <div class="absolute inset-0 opacity-[0.02] bg-[linear-gradient(rgba(59,130,246,0.5)_1px,transparent_1px),linear-gradient(90deg,rgba(59,130,246,0.5)_1px,transparent_1px)] bg-[size:60px_60px]"></div>
    </div>

    <!-- Main Content -->
    <div class="relative z-10">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }
  
  html {
    scroll-behavior: smooth;
  }
  
  body {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  ::-webkit-scrollbar {
    width: 6px;
  }

  ::-webkit-scrollbar-track {
    background: transparent;
  }

  ::-webkit-scrollbar-thumb {
    background: rgba(59, 130, 246, 0.25);
    border-radius: 3px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: rgba(59, 130, 246, 0.45);
  }

  /* Glass Morphism - 凸起玻璃质感 */
  .glass-card {
    padding: 1.5rem;
    background: 
      /* 内部光泽 - 从左上到右下 */
      linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.4) 0%,
        rgba(255, 255, 255, 0.1) 50%,
        rgba(255, 255, 255, 0.05) 100%
      ),
      /* 基础透明 */
      rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(20px) saturate(200%);
    -webkit-backdrop-filter: blur(20px) saturate(200%);
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow: 
      /* 外层大阴影 - 悬浮感 */
      0 20px 50px rgba(59, 130, 246, 0.1),
      /* 中层阴影 */
      0 10px 25px rgba(59, 130, 246, 0.08),
      /* 内层阴影 */
      0 4px 12px rgba(59, 130, 246, 0.05),
      /* 顶部高光 */
      inset 0 1px 0 rgba(255, 255, 255, 0.8),
      /* 底部暗边 - 玻璃厚度感 */
      inset 0 -1px 0 rgba(255, 255, 255, 0.2),
      inset 0 -20px 30px rgba(59, 130, 246, 0.02);
    position: relative;
    overflow: hidden;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  /* 顶部强高光 */
  .glass-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.9),
      transparent
    );
    border-radius: 50%;
  }

  /* 玻璃悬停效果 */
  .glass-card-hover {
    cursor: pointer;
  }
  
  .glass-card-hover:hover {
    background: 
      linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.5) 0%,
        rgba(255, 255, 255, 0.15) 50%,
        rgba(255, 255, 255, 0.1) 100%
      ),
      rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.65);
    box-shadow: 
      0 25px 60px rgba(59, 130, 246, 0.15),
      0 15px 35px rgba(59, 130, 246, 0.1),
      0 6px 15px rgba(59, 130, 246, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      inset 0 -1px 0 rgba(255, 255, 255, 0.25),
      inset 0 -25px 40px rgba(59, 130, 246, 0.03);
    transform: translateY(-4px);
  }

  /* Entry animation */
  @keyframes slideUp {
    0% {
      opacity: 0;
      transform: translateY(24px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .glass-enter {
    opacity: 0;
    animation: slideUp 0.5s ease-out forwards;
  }

  /* Glass card animation */
  @keyframes slideUpCard {
    0% {
      opacity: 0;
      transform: translateY(30px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .glass-card-animate {
    animation: slideUpCard 0.6s ease-out forwards;
    -webkit-animation: slideUpCard 0.6s ease-out forwards;
  }

  /* Print Styles - Professional Resume Layout */
  @media print {
    @page {
      size: A4 portrait;
      margin: 8mm 10mm;
      marks: none;
    }

    html, body {
      background: white !important;
      color: #1e293b !important;
      font-size: 9pt;
      line-height: 1.35;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    /* Main content container */
    main {
      padding: 0 !important;
      max-width: 100% !important;
      margin: 0 !important;
    }

    /* Single column layout */
    .grid {
      display: block !important;
    }

    .lg\:grid-cols-12 {
      display: flex !important;
      flex-direction: column !important;
    }

    .lg\:col-span-4,
    .lg\:col-span-8 {
      width: 100% !important;
      max-width: 100% !important;
    }

    .lg\:sticky {
      position: static !important;
    }

    /* Hide background elements */
    .fixed,
    [class*="animate-"],
    .print\:hidden,
    .sr-only {
      display: none !important;
    }

    /* Remove geometric background */
    .fixed.inset-0 {
      display: none !important;
    }

    /* Reset glass card for print - professional style */
    .glass-card {
      background: white !important;
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
      border: none !important;
      box-shadow: none !important;
      border-radius: 0 !important;
      padding: 0 !important;
      margin-bottom: 6pt !important;
      page-break-inside: avoid;
    }

    .glass-card::before {
      display: none !important;
    }

    .glass-card-hover:hover {
      transform: none !important;
      box-shadow: none !important;
    }

    /* Section title - clean professional style */
    .glass-card > h2 {
      font-size: 9.5pt !important;
      font-weight: 600 !important;
      margin-bottom: 4pt !important;
      padding-bottom: 2pt !important;
      border-bottom: 0.5pt solid #cbd5e1 !important;
      color: #1e293b !important;
      letter-spacing: 0.3pt;
    }

    /* Spacing adjustments */
    .space-y-6 > :not([hidden]) ~ :not([hidden]) {
      margin-top: 4pt !important;
    }

    .space-y-5 > :not([hidden]) ~ :not([hidden]) {
      margin-top: 3pt !important;
    }

    .space-y-4 > :not([hidden]) ~ :not([hidden]) {
      margin-top: 3pt !important;
    }

    .space-y-2 > :not([hidden]) ~ :not([hidden]) {
      margin-top: 2pt !important;
    }

    .space-y-2\.5 > :not([hidden]) ~ :not([hidden]) {
      margin-top: 2.5pt !important;
    }

    .gap-6 {
      gap: 6pt !important;
    }

    .gap-4 {
      gap: 4pt !important;
    }

    .gap-3 {
      gap: 3pt !important;
    }

    .gap-2 {
      gap: 2pt !important;
    }

    .gap-1\.5 {
      gap: 1.5pt !important;
    }

    /* Hero section - centered layout */
    .lg\:col-span-4 .glass-card:first-child {
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      text-align: center !important;
      padding: 6pt 4pt !important;
      border-bottom: 0.5pt solid #e2e8f0 !important;
      margin-bottom: 6pt !important;
    }

    /* Avatar - centered above info */
    .lg\:col-span-4 .glass-card:first-child .relative.flex-shrink-0 {
      margin-bottom: 4pt !important;
      margin-right: 0 !important;
    }

    .lg\:col-span-4 .glass-card:first-child .w-24,
    .lg\:col-span-4 .glass-card:first-child .lg\:w-28,
    .lg\:col-span-4 .glass-card:first-child .w-24.h-24 {
      width: 48pt !important;
      height: 48pt !important;
      min-width: 48pt !important;
    }

    .lg\:col-span-4 .glass-card:first-child .rounded-full {
      border-radius: 50% !important;
    }

    .lg\:col-span-4 .glass-card:first-child .border-\[2\.5px\] {
      border-width: 0.75pt !important;
      border-color: #94a3b8 !important;
    }

    .lg\:col-span-4 .glass-card:first-child .shadow-xl {
      box-shadow: none !important;
    }

    .lg\:col-span-4 .glass-card:first-child .absolute.-inset-3 {
      display: none !important;
    }

    /* Hero info */
    .lg\:col-span-4 .glass-card:first-child .flex-1 {
      width: 100% !important;
    }

    .lg\:col-span-4 .glass-card:first-child .text-center {
      text-align: center !important;
    }

    .lg\:col-span-4 .glass-card:first-child .lg\:text-left {
      text-align: center !important;
    }

    /* Hero text */
    .lg\:col-span-4 .glass-card:first-child .text-xl,
    .lg\:col-span-4 .glass-card:first-child .lg\:text-2xl {
      font-size: 14pt !important;
      font-weight: 700 !important;
      line-height: 1.2 !important;
      margin-bottom: 1pt !important;
      color: #0f172a !important;
    }

    .lg\:col-span-4 .glass-card:first-child .text-blue-600 {
      font-size: 9pt !important;
      margin-bottom: 3pt !important;
      color: #2563eb !important;
    }

    .lg\:col-span-4 .glass-card:first-child .text-sm {
      font-size: 8.5pt !important;
      line-height: 1.35 !important;
      margin-bottom: 3pt !important;
      color: #475569 !important;
    }

    .lg\:col-span-4 .glass-card:first-child .text-slate-500 {
      font-size: 8pt !important;
      line-height: 1.3 !important;
      margin-bottom: 2pt !important;
    }

    .lg\:col-span-4 .glass-card:first-child .max-w-lg {
      max-width: 100% !important;
      margin: 0 auto !important;
    }

    .lg\:col-span-4 .glass-card:first-child .leading-relaxed {
      line-height: 1.35 !important;
    }

    .lg\:col-span-4 .glass-card:first-child .mb-4 {
      margin-bottom: 3pt !important;
    }

    .lg\:col-span-4 .glass-card:first-child .mb-2 {
      margin-bottom: 2pt !important;
    }

    /* Social icons - centered */
    .lg\:col-span-4 .glass-card:first-child .flex.justify-center,
    .lg\:col-span-4 .glass-card:first-child .flex.gap-2 {
      justify-content: center !important;
      gap: 2pt !important;
      margin-bottom: 0 !important;
    }

    .lg\:col-span-4 .glass-card:first-child .w-9,
    .lg\:col-span-4 .glass-card:first-child .h-9 {
      width: 12pt !important;
      height: 12pt !important;
      min-width: 12pt !important;
    }

    .lg\:col-span-4 .glass-card:first-child .w-4.h-4 {
      width: 8pt !important;
      height: 8pt !important;
    }

    /* Hide CTA button in print */
    .lg\:col-span-4 .glass-card:first-child a[href^="mailto"] {
      display: none !important;
    }

    /* Hide decorative elements */
    .backdrop-blur-sm {
      backdrop-filter: none !important;
      background: transparent !important;
    }

    .bg-white\/30,
    .bg-white\/35,
    .bg-white\/40,
    .bg-white\/50,
    .bg-white\/15,
    .bg-white\/25,
    .bg-white\/60 {
      background: transparent !important;
    }

    .border-white\/20,
    .border-white\/30,
    .border-white\/35,
    .border-white\/40,
    .border-white\/50,
    .border-white\/60 {
      border: none !important;
    }

    /* Remove gradients */
    .bg-gradient-to-r,
    .bg-gradient-to-br,
    .bg-gradient-to-bl {
      background: none !important;
    }

    /* Timeline - cleaner look */
    .absolute.left-\[9px\] {
      left: 5px !important;
    }

    .absolute.left-0 {
      left: -1px !important;
    }

    .w-4.h-4 {
      width: 7pt !important;
      height: 7pt !important;
    }

    .w-1\.5.h-1\.5 {
      width: 2.5pt !important;
      height: 2.5pt !important;
    }

    .pl-7 {
      padding-left: 10pt !important;
    }

    /* Timeline line */
    .absolute.left-\[8px\] {
      left: 4.5px !important;
      width: 0.5pt !important;
    }

    /* Experience items */
    .space-y-5 {
      gap: 0 !important;
    }

    .text-base {
      font-size: 9pt !important;
    }

    .text-sm {
      font-size: 8.5pt !important;
    }

    .text-xs {
      font-size: 8pt !important;
    }

    /* Skills tags - compact */
    .glass-card .flex.flex-wrap {
      gap: 1.5pt !important;
    }

    .glass-card .px-2\.5,
    .glass-card .py-1 {
      padding: 0.5pt 2.5pt !important;
      font-size: 7.5pt !important;
      border: 0.5pt solid #e2e8f0 !important;
      border-radius: 2pt !important;
      background: #f8fafc !important;
      color: #334155 !important;
    }

    /* Sub-items in cards */
    .glass-card .p-3 {
      padding: 3pt !important;
    }

    .glass-card .gap-3 {
      gap: 3pt !important;
    }

    .glass-card .space-y-2\.5 {
      gap: 2pt !important;
    }

    /* Education & Awards cards */
    .glass-card .p-3.rounded-lg {
      padding: 2.5pt !important;
      border: none !important;
      border-bottom: 0.5pt dashed #e2e8f0 !important;
      border-radius: 0 !important;
      background: transparent !important;
    }

    .glass-card .p-2 {
      padding: 2pt !important;
    }

    .glass-card .w-9.h-9 {
      width: 11pt !important;
      height: 11pt !important;
    }

    .glass-card .w-9.h-9 .w-4.h-4 {
      width: 7pt !important;
      height: 7pt !important;
    }

    /* Page breaks */
    h1, h2, h3, h4, h5, h6 {
      page-break-after: avoid;
      break-after: avoid;
    }

    .glass-card {
      page-break-after: auto;
    }

    /* Experience section special handling */
    .glass-card .relative .space-y-1\.5 {
      gap: 1.5pt !important;
    }

    /* Links */
    a {
      color: #2563eb !important;
      text-decoration: none !important;
    }

    /* Summary/About section */
    .text-slate-500 {
      font-size: 8.5pt !important;
      line-height: 1.4 !important;
    }

    .glass-card .space-y-2 > :not([hidden]) ~ :not([hidden]) {
      margin-top: 3pt !important;
    }

    .glass-card h2.mb-2,
    .glass-card h2.mb-4 {
      margin-bottom: 3pt !important;
    }

    .glass-card .leading-relaxed {
      line-height: 1.4 !important;
    }

    /* Highlight bullets */
    .text-cyan-500,
    .text-cyan-600 {
      font-size: 8pt !important;
      color: #0891b2 !important;
    }

    /* Contact info */
    .glass-card .text-xs.text-slate-500 {
      font-size: 7.5pt !important;
    }
  }
</style>
