---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { 
  title, 
  description = "Personal Resume - Full Stack Engineer",
  image = "/og-image.svg"
} = Astro.props;

const siteUrl = Astro.site ? Astro.site.href : 'https://example.com';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#4F46E5" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${image}`} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${image}`} />

    <!-- Preconnect to fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&display=swap" rel="stylesheet">

    <!-- Inline font-face with display swap for performance -->
    <style is:global>
      @font-face {
        font-family: 'Noto Sans SC';
        font-style: normal;
        font-weight: 400 700;
        font-display: swap;
        src: url(https://fonts.gstatic.com/s/notisanssc/v15/nwpBtKy2OAdR1K-IwhWudF-R9QMylBJAV3Bo8Kw47FEN_io6npfB.woff2) format('woff2');
        unicode-range: U+4E00-9FFF, U+3400-4DBF, U+3000-303F;
      }
    </style>

    <title>{title}</title>
  </head>
    <body class="bg-gradient-to-br from-slate-50 via-blue-50 to-purple-50 text-slate-800 min-h-screen overflow-x-hidden font-['Noto_Sans_SC',system-ui,sans-serif]">
    <!-- Background Layer -->
    <div class="fixed inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-blue-50 to-purple-50"></div>
      
      <!-- Reduced gradient orbs for better performance -->
      <div class="absolute top-0 -left-20 w-[400px] h-[400px] bg-purple-200/40 rounded-full mix-blend-normal filter blur-[100px] animate-float"></div>
      <div class="absolute top-1/4 -right-20 w-[500px] h-[500px] bg-blue-200/40 rounded-full mix-blend-normal filter blur-[120px] animate-float-delayed"></div>
      <div class="absolute -bottom-20 left-1/4 w-[400px] h-[400px] bg-pink-200/30 rounded-full mix-blend-normal filter blur-[100px] animate-float-slow"></div>
      
      <!-- Subtle texture -->
      <div class="absolute inset-0 opacity-[0.02] bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI1MCIgaGVpZ2h0PSI1MCI+CjxyZWN0IHdpZHRoPSI1MCIgaGVpZ2h0PSI1MCIgZmlsbD0ibm9uZSIvPgo8cmVjdCB3aWR0aD0iMSIgaGVpZ2h0PSIxIiBmaWxsPSIjZmZmIi8+Cjwvc3ZnPg==')]"></div>
    </div>

    <!-- Main Content -->
    <div class="relative z-10">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }
  
  html {
    scroll-behavior: smooth;
  }
  
  body {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  ::-webkit-scrollbar {
    width: 8px;
  }

  ::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.03);
  }

  ::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.15);
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: rgba(0, 0, 0, 0.25);
  }

  .animation-delay-100 { animation-delay: 100ms; }
  .animation-delay-200 { animation-delay: 200ms; }
  .animation-delay-300 { animation-delay: 300ms; }
  .animation-delay-400 { animation-delay: 400ms; }
  .animation-delay-500 { animation-delay: 500ms; }
  .animation-delay-600 { animation-delay: 600ms; }
  .animation-delay-700 { animation-delay: 700ms; }
  .animation-delay-800 { animation-delay: 800ms; }

  .glass {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.8);
    box-shadow: 
      0 8px 32px rgba(31, 38, 135, 0.08),
      0 2px 8px rgba(31, 38, 135, 0.04);
  }

  .glass-strong {
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255, 255, 255, 0.9);
    box-shadow: 
      0 8px 32px rgba(31, 38, 135, 0.1),
      0 2px 8px rgba(31, 38, 135, 0.05);
  }
</style>
